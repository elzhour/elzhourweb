rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null;
    }

    // Players
    match /players/{playerId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == playerId;
    }

    // Coaches
    match /coaches/{coachId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == coachId;
    }

    // Ratings - coaches can write, all authenticated can read
    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // Attendance - coaches can write, all authenticated can read
    match /attendance/{attendanceId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // FCM tokens - users can write their own token
    match /fcmTokens/{tokenId} {
      allow read, write: if request.auth != null;
    }

    // Notification queue - clients write, Cloud Function reads/deletes
    match /notificationQueue/{docId} {
      allow create: if request.auth != null;
      allow read, delete: if false; // only Cloud Function can read/delete
    }

    // Shared settings (session date etc.) - coaches write, all read
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
